# SIXX Vault — environment template
# Copy to `.env` and fill in real values. `.env` is gitignored (see .gitignore).
# NEVER commit `.env`.

# ─── Deployer ────────────────────────────────────────────────
# 0x-prefixed 32-byte private key. Use a fresh testnet-only key.
PRIVATE_KEY=

# ─── RPC endpoints ───────────────────────────────────────────
# Arbitrum One mainnet (used for fork tests in test/AaveV3Adapter.t.sol)
ARB_RPC_URL=

# Arbitrum Sepolia (testnet deploy target — chain 421614)
ARB_SEPOLIA_RPC_URL=

# Ethereum mainnet (used for fork tests if you add ETH-mainnet adapters)
ETH_RPC_URL=

# Ethereum Sepolia (testnet deploy target — chain 11155111)
ETH_SEPOLIA_RPC_URL=

# ─── Block explorer verification keys ────────────────────────
# Arbiscan (covers both Arbitrum One and Arbitrum Sepolia)
ARBISCAN_API_KEY=

# Etherscan mainnet
ETHERSCAN_API_KEY=

# Etherscan Sepolia (separate key required; get one at https://etherscan.io/myapikey)
ETH_SEPOLIA_ETHERSCAN_API_KEY=
